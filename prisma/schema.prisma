generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String               @id @default(cuid())
  email                 String?              @unique
  password              String
  name                  String?
  role                  String               @default("operator")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  status                String               @default("enabled")
  allowedPages          String               @default("")
  defaultHomePage       String               @default("/dashboard/workbench")
  department            String?
  notes                 String?
  permissionMode        String               @default("role")
  requirePasswordChange Boolean              @default(false)
  phone                 String?              @unique
  ownVideoMetrics       OwnVideoMetric[]
  edits                 ScriptBreakdown[]    @relation("BreakdownEditor")
  updateLogs            ScriptUpdateLog[]
  scriptAnalyses        ScriptUserAnalysis[]
  tasksAssigned         TrainingTask[]       @relation("TaskAssignee")
  tasksCreated          TrainingTask[]       @relation("TaskCreator")
  tasksOwned            TrainingTask[]       @relation("TaskOwner")
  scripts               ViralScript[]
  viralVideoAnalyses    ViralVideoAnalysis[] @relation("ViralVideoCreator")
  viralVideoUpdates     ViralVideoAnalysis[] @relation("ViralVideoUpdater")
  workTasksAssigned     WorkTask[]           @relation("WorkTaskAssignee")
  workTasksCreated      WorkTask[]           @relation("WorkTaskCreator")
  workTasksOwned        WorkTask[]           @relation("WorkTaskOwner")

  @@index([email])
  @@index([phone])
}

model Product {
  id                       String      @id @default(cuid())
  name                     String
  sku                      String?     @unique
  skuId                    String?
  image                    String?
  images                   String?
  description              String?
  material                 String?
  length                   String?
  color                    String?
  style                    String?
  costCny                  Float       @default(0)
  priceUsd                 Float       @default(0)
  tiktokPriceUsd           Float?
  tiktokDiscountPriceUsd   Float?
  stock                    Int         @default(0)
  scene                    String?
  materialUrl              String?
  warningStock             Boolean     @default(false)
  warningProfit            Boolean     @default(false)
  warningMissing           Boolean     @default(false)
  tags                     String?
  notes                    String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  adCostUsd                Float       @default(0)
  discountPriceUsd         Float?
  firstLegLogisticsCostUsd Float       @default(0)
  influencerCommissionUsd  Float       @default(0)
  laceSize                 String?
  lastLegLogisticsCostUsd  Float       @default(0)
  assignee                 String?
  collectedAt              DateTime?
  mainConfirmedAt          DateTime?
  nextAction               String?
  outreachLinkedAt         DateTime?
  pickedUpAt               DateTime?
  postedAt                 DateTime?
  sampleSentAt             DateTime?
  scriptReadyAt            DateTime?
  storyboardReadyAt        DateTime?
  workflowStatus           String      @default("待收集")
  productUrl               String?
  isActive                 Boolean     @default(true)
  tiktokSync               TiktokSync?
}

model TiktokSync {
  id               String   @id @default(cuid())
  sku              String   @unique
  skuId            String?
  title            String?
  priceUsd         Float    @default(0)
  originalPriceUsd Float?
  stock            Int      @default(0)
  status           String?
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [sku], references: [sku])
}

model PerformanceDaily {
  id          String   @id @default(cuid())
  date        DateTime
  sku         String
  productName String?
  productLine String?
  owner       String?
  gmv         Float    @default(0)
  orders      Int      @default(0)
  adsCost     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, sku])
  @@index([date])
  @@index([sku])
}

model PerformanceMeta {
  id                 String    @id @default(cuid())
  lastOrdersImportAt DateTime?
  lastAdsImportAt    DateTime?
  lastImportedBy     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ViralScript {
  id               String                  @id @default(cuid())
  title            String
  platform         String?
  sourceUrl        String?
  productSku       String?
  tags             String?
  status           String                  @default("active")
  createdById      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  breakdowns       ScriptBreakdown[]
  standardAnalysis ScriptStandardAnalysis?
  updateLogs       ScriptUpdateLog[]
  userAnalyses     ScriptUserAnalysis[]
  tasks            TrainingTask[]
  createdBy        User?                   @relation(fields: [createdById], references: [id])

  @@index([productSku])
  @@index([updatedAt])
}

model ScriptStandardAnalysis {
  id               String      @id @default(cuid())
  scriptId         String      @unique
  positionAnalysis String      @default("")
  hookAnalysis     String      @default("")
  rhythmAnalysis   String      @default("")
  shotAnalysis     String      @default("")
  subtitleAnalysis String      @default("")
  whyItWorked      String      @default("")
  whatToWatch      String      @default("")
  commonMistakes   String      @default("")
  todayExecution   String      @default("")
  updatedAt        DateTime    @updatedAt
  createdAt        DateTime    @default(now())
  script           ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model ScriptUserAnalysis {
  id               String      @id @default(cuid())
  scriptId         String
  userId           String
  positionAnalysis String      @default("")
  hookAnalysis     String      @default("")
  rhythmAnalysis   String      @default("")
  shotAnalysis     String      @default("")
  subtitleAnalysis String      @default("")
  whyItWorked      String      @default("")
  whatToWatch      String      @default("")
  commonMistakes   String      @default("")
  todayExecution   String      @default("")
  isLearned        Boolean     @default(false)
  isPracticing     Boolean     @default(false)
  submitStatus     String      @default("draft")
  storyboard       String?
  updatedAt        DateTime    @updatedAt
  createdAt        DateTime    @default(now())
  script           ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scriptId, userId])
  @@index([userId, updatedAt])
  @@index([scriptId, updatedAt])
}

model ScriptBreakdown {
  id         String      @id @default(cuid())
  scriptId   String
  version    Int         @default(1)
  content    String
  editedById String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  editedBy   User?       @relation("BreakdownEditor", fields: [editedById], references: [id])
  script     ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, version])
  @@index([updatedAt])
}

model ScriptUpdateLog {
  id                    String      @id @default(cuid())
  scriptId              String
  summary               String
  impactScope           String?
  impactArea            String?
  createdById           String?
  createdByNameSnapshot String?
  createdByRoleSnapshot String?
  createdAt             DateTime    @default(now())
  breakdownId           String?
  breakdownVersion      Int?
  createdBy             User?       @relation(fields: [createdById], references: [id])
  script                ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([scriptId, createdAt])
}

model TrainingTask {
  id          String       @id @default(cuid())
  title       String
  focus       String?
  requirement String?
  dueAt       DateTime?
  status      String       @default("todo")
  scriptId    String?
  assigneeId  String
  ownerId     String?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignee    User         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy   User?        @relation("TaskCreator", fields: [createdById], references: [id])
  owner       User?        @relation("TaskOwner", fields: [ownerId], references: [id])
  script      ViralScript? @relation(fields: [scriptId], references: [id])

  @@index([assigneeId, status])
  @@index([dueAt])
  @@index([createdAt])
}

model WorkTask {
  id                      String    @id @default(cuid())
  taskKey                 String    @unique
  title                   String
  sourceModule            String
  taskType                String    @default("personal")
  priority                String
  dueDate                 DateTime
  status                  String
  relatedEntityId         String
  note                    String?
  originalDueDate         DateTime?
  delayDays               Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  assigneeName            String?
  assigneeUserId          String?
  completedAt             DateTime?
  completedLink           String?
  completedNote           String?
  completedResult         String?
  creatorName             String?
  creatorUserId           String?
  isTodayMustDo           Boolean   @default(false)
  ownerName               String?
  ownerUserId             String?
  relatedEntityType       String    @default("custom")
  remindAt                DateTime?
  requireCompletionLink   Boolean   @default(false)
  requireCompletionNote   Boolean   @default(false)
  requireCompletionResult Boolean   @default(false)
  workspaceId             String?
  department              String?
  collaboratorUserIds     String[]
  assignee                User?     @relation("WorkTaskAssignee", fields: [assigneeUserId], references: [id])
  creator                 User?     @relation("WorkTaskCreator", fields: [creatorUserId], references: [id])
  owner                   User?     @relation("WorkTaskOwner", fields: [ownerUserId], references: [id])

  @@index([assigneeUserId, status])
  @@index([creatorUserId, status])
  @@index([ownerUserId, status])
  @@index([dueDate])
  @@index([sourceModule, relatedEntityId])
  @@index([isTodayMustDo])
  @@index([workspaceId])
  @@index([taskType])
  @@index([department])
}

model TikTokSyncLog {
  id        String   @id @default(cuid())
  type      String
  status    String
  message   String?
  dataCount Int      @default(0)
  createdAt DateTime @default(now())
}

model Influencer {
  id               String                     @id @default(cuid())
  nickname         String
  platform         String
  profileUrl       String?
  country          String?
  followers        Int                        @default(0)
  contentTypes     Json?
  productLines     Json?
  matchProducts    Json?
  status           String                     @default("to_outreach")
  owner            String                     @default("运营")
  potential        String                     @default("C")
  email            String?
  whatsapp         String?
  phone            String?
  language         String?
  tags             Json?
  lastFollowUpAt   DateTime?
  lastFollowUpNote String?
  firstContactAt   DateTime?
  nextFollowUpAt   DateTime?
  nextAction       String?
  timeline         Json?
  quote            Json?
  sample           Json?
  deliverables     Json?
  review           Json?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  instagram        String?
  otherContact     String?
  cooperationLevel String                     @default("normal")
  deepFrequency    String?
  deepKeyProducts  Json?
  deepNotes        String?
  deepRequirements String?
  sampleShipments  InfluencerSampleShipment[]

  @@index([status])
  @@index([cooperationLevel])
  @@index([owner])
  @@index([updatedAt])
}

model InfluencerSampleShipment {
  id             String                 @id @default(cuid())
  influencerId   String
  sampleRound    Int                    @default(1)
  sampleDate     DateTime?
  status         String                 @default("pending")
  trackingNumber String?
  notes          String?
  createdBy      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  items          InfluencerSampleItem[]
  influencer     Influencer             @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId])
  @@index([status])
  @@index([createdAt])
}

model InfluencerSampleItem {
  id          String                   @id @default(cuid())
  shipmentId  String
  productId   String?
  sku         String?
  productName String
  color       String?
  length      String?
  quantity    Int                      @default(1)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  shipment    InfluencerSampleShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

model ProductOpportunity {
  id              String   @id @default(cuid())
  name            String
  category        String?
  styleType       String?
  heatLevel       String   @default("中")
  sourceNote      String?
  existingSimilar String?
  diffPoints      String?
  suggestedAction String   @default("观察")
  priority        String   @default("中")
  assignee        String?
  notes           String?
  status          String   @default("可观察")
  productId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assignee])
}

model ViralVideoAnalysis {
  id                   String   @id @default(cuid())
  title                String
  platform             String   @default("TikTok")
  sourceUrl            String?
  videoDuration        Int      @default(0)
  viewCount            Int      @default(0)
  likeCount            Int      @default(0)
  commentCount         Int      @default(0)
  shareCount           Int      @default(0)
  hookAnalysis         String   @default("")
  sellingPointAnalysis String   @default("")
  rhythmAnalysis       String   @default("")
  visualAnalysis       String   @default("")
  audioAnalysis        String   @default("")
  reusableElements     String   @default("")
  applicableScenes     String   @default("")
  productSku           String?
  tags                 String   @default("")
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  updatedById          String?
  createdBy            User?    @relation("ViralVideoCreator", fields: [createdById], references: [id])
  updatedBy            User?    @relation("ViralVideoUpdater", fields: [updatedById], references: [id])

  @@index([platform])
  @@index([productSku])
  @@index([createdAt])
  @@index([viewCount])
}

model OwnVideoMetric {
  id             String   @id @default(cuid())
  title          String
  platform       String   @default("TikTok")
  sourceUrl      String?
  videoDuration  Int      @default(0)
  contentType    String   @default("product_showcase")
  productSku     String?
  impressions    Int      @default(0)
  views          Int      @default(0)
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  saves          Int      @default(0)
  clicks         Int      @default(0)
  addToCarts     Int      @default(0)
  orders         Int      @default(0)
  revenue        Float    @default(0)
  completionRate Float    @default(0)
  avgWatchTime   Float    @default(0)
  adSpend        Float    @default(0)
  cpm            Float    @default(0)
  cpc            Float    @default(0)
  publishedAt    DateTime @default(now())
  notes          String   @default("")
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  dropOffSecond  Int?
  retention3s    Float    @default(0)
  retention5s    Float    @default(0)
  createdBy      User?    @relation(fields: [createdById], references: [id])

  @@index([platform])
  @@index([productSku])
  @@index([publishedAt])
  @@index([contentType])
  @@index([createdById])
}
