generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("operator") // admin, operator, editor, optimizer, viewer
  status    String   @default("enabled")  // enabled, disabled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scripts   ViralScript[]
  edits     ScriptBreakdown[] @relation("BreakdownEditor")
  scriptAnalyses ScriptUserAnalysis[]

  updateLogs ScriptUpdateLog[]
  tasksAssigned TrainingTask[] @relation("TaskAssignee")
  tasksOwned   TrainingTask[] @relation("TaskOwner")
  tasksCreated TrainingTask[] @relation("TaskCreator")
}

model Product {
  id          String   @id @default(cuid())
  name        String   // 产品名称
  sku         String?  @unique // 商家SKU
  skuId       String?  // TikTok SKU ID
  image       String?  // 主图URL
  images      String?  // 多图，JSON数组
  description String?  // 产品描述/卖点
  material    String?  // 材质
  length      String?  // 长度
  color       String?  // 颜色
  style       String?  // 款式
  
  // 采购成本 (CNY)
  costCny     Float    @default(0)

  // 头程/尾程物流成本 (USD/每件)
  firstLegLogisticsCostUsd Float @default(0)
  lastLegLogisticsCostUsd  Float @default(0)

  // 蕾丝大小
  laceSize    String?

  // 售价 & 折扣价 (USD)
  priceUsd            Float    @default(0)   // 标价
  discountPriceUsd    Float?                 // 实际成交/折扣价（用于毛利计算，如为空则回退到 priceUsd）
  
  // 达人佣金 & 广告费用 (USD/每件)
  influencerCommissionUsd Float @default(0)
  adCostUsd               Float @default(0)
  
  // TikTok售价相关
  tiktokPriceUsd          Float?  // TikTok展示价
  tiktokDiscountPriceUsd  Float?  // TikTok折扣价
  
  // 库存
  stock       Int      @default(0)
  
  // 核心场景
  scene       String?
  
  // 素材链接
  materialUrl String?
  
  // 预警状态
  warningStock      Boolean @default(false) // 库存预警
  warningProfit     Boolean @default(false) // 低毛利预警
  warningMissing    Boolean @default(false) // 缺信息
  
  // 运营标记
  tags        String?  // JSON数组
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 关联
  tiktokSync  TiktokSync?
}

model TiktokSync {
  id        String   @id @default(cuid())
  sku       String   @unique // 商家SKU
  skuId     String?  // TikTok SKU ID
  title     String?  // 商品标题
  
  // 价格 (USD)
  priceUsd  Float    @default(0)
  originalPriceUsd Float? // 原价
  
  // 库存
  stock     Int      @default(0)
  
  // 状态
  status    String?  // 商品状态
  
  // 同步时间
  syncedAt  DateTime @default(now())
  
  // 关联产品
  product   Product? @relation(fields: [sku], references: [sku])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 每日经营数据（订单 + 广告汇总）
model PerformanceDaily {
  id          String   @id @default(cuid())
  date        DateTime
  sku         String
  productName String?
  productLine String?
  owner       String?

  gmv     Float  @default(0)
  orders  Int    @default(0)
  adsCost Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, sku])
  @@index([date])
  @@index([sku])
}

// 经营数据导入元信息（最近导入时间、导入人）
model PerformanceMeta {
  id               String   @id @default(cuid())
  lastOrdersImportAt DateTime?
  lastAdsImportAt    DateTime?
  lastImportedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Config {
  id    String @id @default(cuid())
  key   String @unique
  value String
  
  // 常用配置
  // - exchange_rate: 汇率 (CNY -> USD)
  // - stock_warning_threshold: 库存预警阈值
  // - profit_margin_warning_threshold: 毛利率预警阈值 (百分比)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 爆款脚本（用于剪辑师拆解）
model ViralScript {
  id          String   @id @default(cuid())
  title       String
  platform    String?  // TikTok / 抖音 / 小红书...
  sourceUrl   String?  // 原视频/脚本链接
  productSku  String?  // 关联产品 SKU（可选）
  tags        String?  // JSON 数组
  status      String   @default("active") // active, archived

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])

  breakdowns  ScriptBreakdown[]
  updateLogs  ScriptUpdateLog[]
  tasks       TrainingTask[]
  standardAnalysis ScriptStandardAnalysis?
  userAnalyses ScriptUserAnalysis[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productSku])
  @@index([updatedAt])
}

// 标准拆解（负责人/运营提供，用于全员参考）
model ScriptStandardAnalysis {
  id        String @id @default(cuid())
  scriptId  String @unique
  script    ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  positionAnalysis  String @default("")
  hookAnalysis      String @default("")
  rhythmAnalysis    String @default("")
  shotAnalysis      String @default("")
  subtitleAnalysis  String @default("")
  whyItWorked       String @default("")
  whatToWatch       String @default("")
  commonMistakes    String @default("")
  todayExecution    String @default("")

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([updatedAt])
}

// 个人拆解（同一脚本每人一份，可编辑自己的并查看他人）
model ScriptUserAnalysis {
  id        String @id @default(cuid())
  scriptId  String
  script    ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  positionAnalysis  String @default("")
  hookAnalysis      String @default("")
  rhythmAnalysis    String @default("")
  shotAnalysis      String @default("")
  subtitleAnalysis  String @default("")
  whyItWorked       String @default("")
  whatToWatch       String @default("")
  commonMistakes    String @default("")
  todayExecution    String @default("")

  isLearned     Boolean @default(false)
  isPracticing  Boolean @default(false)
  submitStatus  String  @default("draft") // draft, submitted, reviewed

  storyboard    Json?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([scriptId, userId])
  @@index([userId, updatedAt])
  @@index([scriptId, updatedAt])
}

// 脚本拆解（支持实时更新 + 版本）
model ScriptBreakdown {
  id          String   @id @default(cuid())
  scriptId    String
  script      ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  version     Int      @default(1)
  content     String   // Markdown / 结构化文本

  editedById  String?
  editedBy    User?    @relation("BreakdownEditor", fields: [editedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scriptId, version])
  @@index([updatedAt])
}

// 今日更新动态（可追溯的团队更新日志）
model ScriptUpdateLog {
  id          String   @id @default(cuid())
  scriptId    String
  script      ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  breakdownId String?
  breakdownVersion Int?

  summary     String   // 更新内容摘要（动作导向）
  impactScope String?  // 影响范围（如：适用于假发类素材 / SKU xxx）
  impactArea  String?  // 影响模块（如：前3秒开头 / 节奏 / 字幕）

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdByNameSnapshot String?
  createdByRoleSnapshot String?

  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([scriptId, createdAt])
}

// 我的今日任务（可指派、可闭环）
model TrainingTask {
  id          String   @id @default(cuid())
  title       String   // 任务标题（动作导向）
  focus       String?  // 重点要改什么
  requirement String?  // 今日练习要求

  dueAt       DateTime?
  status      String   @default("todo") // todo, in_progress, submitted, done, review

  scriptId    String?
  script      ViralScript? @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  assigneeId  String
  assignee    User     @relation("TaskAssignee", fields: [assigneeId], references: [id])

  ownerId     String?  // 负责人（可选）
  owner       User?    @relation("TaskOwner", fields: [ownerId], references: [id])

  createdById String?
  createdBy   User?    @relation("TaskCreator", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([assigneeId, status])
  @@index([dueAt])
  @@index([createdAt])
}

// 达人建联（用于运营协作；timeline 等用 JSON 持久化）
model TikTokSyncLog {
  id        String   @id @default(cuid())
  type      String   // "order", "product", "ad"
  status    String   // "success", "failed"
  message   String?
  dataCount Int      @default(0)
  createdAt DateTime @default(now())
}

model Influencer {
  id        String   @id @default(cuid())
  nickname  String
  platform  String   // TikTok / Instagram / YouTube / Other
  profileUrl String?
  country   String?
  followers Int      @default(0)

  contentTypes   String? // JSON 数组
  productLines   String? // JSON 数组
  matchProducts  String? // JSON 数组

  status    String   @default("to_outreach")
  cooperationLevel String @default("normal") // normal, key, deep
  owner     String   @default("运营")
  potential String   @default("C") // A/B/C

  email     String?
  whatsapp  String?
  phone     String?
  instagram String?
  otherContact String?
  language  String?
  tags      String? // JSON 数组

  // 深度合作（可选，只有 cooperationLevel=deep 时重点使用）
  deepRequirements String?
  deepKeyProducts  String? // JSON 数组
  deepFrequency    String?
  deepNotes        String?

  lastFollowUpAt   DateTime?
  lastFollowUpNote String?
  firstContactAt   DateTime?
  nextFollowUpAt   DateTime?
  nextAction       String? // 下一步动作

  timeline  Json?   // FollowUp[]（JSON）
  quote     Json?
  sample    Json?
  deliverables Json?
  review    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([cooperationLevel])
  @@index([owner])
  @@index([updatedAt])
}
